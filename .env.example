# Copy this file to .env and fill in your keys.
# cp .env.example .env

# Required — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional — powers automatic voice transcription after recording.
# Get yours at https://platform.openai.com/api-keys
# If omitted, users can still type transcripts manually.
OPENAI_API_KEY=sk-...

# Optional — defaults to 3000
PORT=3000

# Optional — override the Claude model used for AI suggestions
# claude-sonnet-4-6 (default, fast & good), claude-opus-4-8 (best quality)
CLAUDE_MODEL=claude-sonnet-4-6
